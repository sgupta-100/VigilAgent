# ── Antigravity V6 Environment Configuration ──
# Copy this to .env and fill in your values

# === Required ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
OPENROUTER_API_KEY=sk-or-...

# === Optional: Redis ===
REDIS_URL=redis://localhost:6379

# === Optional: CORS (comma-separated) ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Alpha V6 Recon Engine ===
ALPHA_ENABLE_V6=true
ALPHA_TOOL_ROOT=D:\projects
ALPHA_ARTIFACT_ROOT=data/scans
ALPHA_DEFAULT_MODE=STANDARD
ALPHA_DEFAULT_RPS=50
ALPHA_MAX_HTTPX_THREADS=50
ALPHA_MAX_CRAWL_DEPTH=3
ALPHA_ENABLE_EXTERNAL_TOOLS=false
ALPHA_TOOL_TIMEOUT_SECONDS=180
ALPHA_EXPLICIT_AUTHORIZATION=false

# === Optional: PinchTab Browser ===
ALPHA_ENABLE_PINCHTAB=true
PINCHTAB_BASE_URL=http://127.0.0.1:9867
PINCHTAB_HEADLESS=true

# === Optional: OpenClaw Browser ===
OPENCLAW_ENABLED=true
OPENCLAW_HEADLESS=true
OPENCLAW_BROWSER=chromium
OPENCLAW_TIMEOUT=30000
OPENCLAW_STEALTH=true
OPENCLAW_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
OPENCLAW_VIEWPORT_WIDTH=1920
OPENCLAW_VIEWPORT_HEIGHT=1080
OPENCLAW_MAX_CONTEXTS=5

# === Optional: Hybrid Browser Orchestration ===
HYBRID_BROWSER_ENABLED=true
HYBRID_DEFAULT_ENGINE=auto
HYBRID_AUTO_FALLBACK=true
HYBRID_SESSION_SHARING=true
HYBRID_FORENSICS_ENABLED=true
HYBRID_FORENSICS_DIR=scan_states/forensics
HYBRID_SESSION_DIR=scan_states/sessions

# === Optional: Neo4j Graph ===
ALPHA_ENABLE_NEO4J=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# === Optional: OpenCTI STIX Export ===
ALPHA_ENABLE_OPENCTI_EXPORT=false
OPENCTI_URL=
OPENCTI_TOKEN=

# === Scan Settings ===
SCAN_TIMEOUT=600

# === Deep System Integration (config/integration.yaml is the source of truth) ===
# These env vars override the YAML for prod / 12-factor deploys. In dev, just
# leave them unset and let config/integration.yaml drive the rollout cohort.

# Task 3.8 — browser learning
ENABLE_BROWSER_LEARNING=true
BROWSER_LEARNING_ROLLOUT_PCT=10

# Task 5.11 — skill library v2
ENABLE_SKILL_LIBRARY_V2=true
SKILL_LIBRARY_ROLLOUT_PCT=25

# Task 7.8 — browser health monitoring
ENABLE_BROWSER_HEALTH_MONITORING=true
HEALTH_MONITORING_ROLLOUT_PCT=50

# Task 9.10 — self-healing engine
ENABLE_SELF_HEALING=true
SELF_HEALING_ROLLOUT_PCT=75

# Task 11.8 — unified knowledge graph
ENABLE_UNIFIED_GRAPH=true
UNIFIED_GRAPH_ROLLOUT_PCT=100

# Task 13.11 — intelligent routing + forensic learning
ENABLE_INTELLIGENT_ROUTING=true
ENABLE_FORENSIC_LEARNING=true
ROUTING_FORENSICS_ROLLOUT_PCT=100

# Resource caps (kept conservative even at 100% rollout)
EVENT_BATCH_SIZE=50
EVENT_BATCH_TIMEOUT_MS=200
MAX_CONCURRENT_LEARNING=8
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_S=60
